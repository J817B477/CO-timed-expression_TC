# creates sample level quality reports for automated trimming decisions
rule raw_qc:
  input:
    'raw_fastqs/{sample}.fastqsanger.gz'
  output:
    fastqc_data = directory('raw_fastqc_reports/{sample}.fastqsanger_fastqc')
  shell:
    """
    #creates output files
    fastqc {input} --extract --outdir raw_fastqc_reports
    rm -r raw_fastqc_reports/{wildcards.sample}.fastqsanger_fastqc.zip
    rm raw_fastqc_reports/{wildcards.sample}.fastqsanger_fastqc.html
    """

# creates raw reads aggregated quality report for automated trimming decisions
rule raw_multiqc:
  input:
    expand("raw_fastqc_reports/{sample}.fastqsanger_fastqc", sample = SAMPLES)
  output:
    html = "raw_fastqc_reports/multiqc_report.html",
    data_dir = directory("raw_fastqc_reports/multiqc_data")

  shell: 
    """
    multiqc raw_fastqc_reports -o raw_fastqc_reports
    """

# generates trim_params.yml that includes call strings for trimming base on raw fastq quality data
rule get_trim_params:
    input:
      qc_txts = expand('raw_fastqc_reports/{report}.fastqsanger_fastqc/fastqc_data.txt', report = SAMPLES),
      multiqc_perbase_seq_qual = 'raw_fastqc_reports/multiqc_data/fastqc_per_base_sequence_quality_plot.txt',
      multiqc_seq_len = 'raw_fastqc_reports/multiqc_data/fastqc_sequence_length_distribution_plot.txt'
    output:
      "trim_params.yml"
    params:
      read_type = config["READ_TYPE"]
    script: 
      "scripts/select_trimTools.py"

# implements trimming using the parameters generated by "get_trim_params" rule
rule raw_trim:
  input:
    raw="raw_fastqs/{sample}.fastqsanger.gz"
  output:
    trimmed="trimmed_fastqs/trimmed_{sample}.fastq.gz"
  params:
    read_type = config["READ_TYPE"],
    trim_calls = load_trim_params(),
    polyA=lambda wildcards: load_trim_params().get("polyA", ""),
    polyG=lambda wildcards: load_trim_params().get("polyG", ""),
    adapter=lambda wildcards: load_trim_params().get("adapter", ""),
    headcrop=lambda wildcards: load_trim_params().get("headcrop", ""),
    crop=lambda wildcards: load_trim_params().get("crop", ""),
    sliding_window=lambda wildcards: load_trim_params().get("sliding_window", ""),
    minlen=lambda wildcards: load_trim_params().get("minlen", "")
  shell:
    """
    {params.polyA}
    {params.polyG}

    trimmomatic {params.read_type} -phred33 {input.raw} {output.trimmed} \
    {params.adapter} \
    {params.headcrop} \
    {params.crop} \
    {params.sliding_window} \
    {params.minlen}
    """

# creates sample level quality reports on trimmed data
rule trimmed_qc:
  input:
    'trimmed_fastqs/trimmed_{sample}.fastq.gz'
  output:
    fastqc_data = directory('trimmed_fastqc_reports/trimmed_{sample}_fastqc')
  shell:
    """
    #creates output files
    fastqc {input} --extract --outdir trimmed_fastqc_reports
    rm -r trimmed_fastqc_reports/trimmed_{wildcards.sample}_fastqc.zip
    rm trimmed_fastqc_reports/trimmed_{wildcards.sample}_fastqc.html
    """

# creates aggregate quality check report from trimmed semple level quality reports
rule trimmed_multiqc:
  input:
    expand("trimmed_fastqc_reports/trimmed_{sample}_fastqc", sample = SAMPLES)
  output:
    html = "trimmed_fastqc_reports/multiqc_report.html",
    data_dir = directory("trimmed_fastqc_reports/multiqc_data")

  shell: 
    """
    multiqc trimmed_fastqc_reports -o trimmed_fastqc_reports
    """

#creates BAM alignment file using BWA MEM software for alignment
rule align_reads:
  input:
    trimmed_fq = "trimmed_fastqs/trimmed_{sample}.fastq.gz"
  output:
    out = "bams/{sample}.sorted.bam"
  params:
    ref_genome = config["REF"]["fasta"]
  threads: 8
  shell:
    """
    bwa mem -t {threads} {params.ref_genome} {input.trimmed_fq}\
    | samtools view -bS - \
    | samtools sort -@{threads} -o {output.out}

    samtools index {output.out}
    """

# establishes single counts matrix from bam alignment files
rule get_counts:
  input:
    bams = expand("bams/{sample}.sorted.bam", sample = SAMPLES)
  output:
    counts = "counts.txt"
  params:
    ref_genome = config["REF"]["gtf"]
  threads: 2
  shell:
    """
    featureCounts \
    -T {threads} \
    -a {params.ref_genome} \
    -t exon \
    -g gene_id \
    -o {output.counts} \
    {input.bams}
    """
# cleans the sample identifiers and generates version of counts dataframes
rule clean_counts:
  input:
    "counts.txt"
  output:
    "de_analysis/counts_matrix.csv",
    "de_analysis/tpm_counts.csv"
  script:
    "scripts/clean_counts.R"

# establishes experiment's differentially expressed genes
rule differential_expression:
  input:
    "de_analysis/tpm_counts.csv"
  output:
    "de_analysis/fullDE_tpm_counts.csv",
    "de_analysis/sigDE_tpm_counts.csv"
  script:
    "scripts/DEanalysis.R"

