# reference configuration file: provides project level values
configfile: "config.yml"

# library dependencies
import yaml

# gets dynamically generated trim parameters from yml file
def load_trim_params():
  with open ("trim_params.yml") as f:
    params = yaml.safe_load(f)
  return params

# assigns sample identifiers from config file
SAMPLES = config["SAMPLES"]

# target rule that drives the production of pipeline
rule all:
  input: 
    "de_analysis/fullDE_tpm_counts.csv",
    "de_analysis/sigDE_tpm_counts.csv"
